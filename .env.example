# Postgres connection string (hosted, e.g. Neon, in production; local Postgres
# in dev). For a Homebrew local Postgres: postgresql://localhost:5432/healthmaxxing
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Shared secret the /api/ingest route requires as `Authorization: Bearer <token>`.
# Generate one with: openssl rand -base64 32
INGEST_SECRET=changeme

# Shared secret the MCP server (/api/mcp) requires as `Authorization: Bearer <token>`.
# Generate one with: openssl rand -base64 32
MCP_SECRET=changeme
